{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-powerpack.local/schemas/project-facts.schema.json",
  "title": "Codex Powerpack project facts",
  "type": "object",
  "required": ["schema_version", "project_root", "project_fingerprint", "git_repository", "project_type", "languages", "frameworks", "source_file_count", "total_file_count", "documentation_file_count", "binary_or_media_count", "monorepo", "commands", "existing_codex", "risks", "unknowns"],
  "properties": {
    "schema_version": {"const": 1},
    "generated_at": {"type": "string"},
    "project_root": {"type": "string"},
    "project_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_repository": {"type": "boolean"},
    "project_type": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "languages": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "frameworks": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "package_managers": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "dev_dependencies": {"type": "array", "items": {"type": "string"}},
    "databases": {"type": "array", "items": {"type": "string"}},
    "orms": {"type": "array", "items": {"type": "string"}},
    "testing": {"type": "array", "items": {"type": "string"}},
    "linters": {"type": "array", "items": {"type": "string"}},
    "type_checkers": {"type": "array", "items": {"type": "string"}},
    "build_tools": {"type": "array", "items": {"type": "string"}},
    "ci": {"type": "array", "items": {"type": "string"}},
    "containers": {"type": "array", "items": {"type": "string"}},
    "infrastructure": {"type": "array", "items": {"type": "string"}},
    "entry_points": {"type": "array", "items": {"type": "string"}},
    "source_roots": {"type": "array", "items": {"type": "string"}},
    "test_roots": {"type": "array", "items": {"type": "string"}},
    "documentation_roots": {"type": "array", "items": {"type": "string"}},
    "generated_roots": {"type": "array", "items": {"type": "string"}},
    "source_file_count": {"type": "integer", "minimum": 0},
    "total_file_count": {"type": "integer", "minimum": 0},
    "documentation_file_count": {"type": "integer", "minimum": 0},
    "binary_or_media_count": {"type": "integer", "minimum": 0},
    "monorepo": {"type": "boolean"},
    "services": {"type": "array", "items": {"type": "string"}},
    "commands": {"type": "object", "required": ["install", "build", "lint", "typecheck", "test", "e2e", "dev"], "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "existing_codex": {"type": "object", "required": ["agents_md", "config_toml", "skills", "agents", "mcp_servers"], "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "manifest_files": {"type": "array", "items": {"type": "string"}},
    "tree_summary": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "unknowns": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
