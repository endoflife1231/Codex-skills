{
  "id": "graphify",
  "name": "Graphify",
  "type": "project-graph",
  "optional": true,
  "source": "sources/graphify",
  "verified_local_commands": [
    "graphify update .",
    "graphify query \"<question>\"",
    "graphify export html",
    "graphify hook install"
  ],
  "non_goals": [
    "auto-installing graphifyy",
    "running the upstream broad project installer",
    "auto-enabling hooks or watchers",
    "requiring Graphify for core pack functionality",
    "using curl-piped installers"
  ],
  "outputs": [
    "graphify-out/graph.json",
    "graphify-out/GRAPH_REPORT.md"
  ],
  "default_scope": "project",
  "default_enabled": "auto",
  "profiles": {"minimal": "optional", "standard": "auto", "full": "auto"},
  "managed_state": ".codex-powerpack/state/graphify.json",
  "routing": {
    "use_for": ["documentation", "PDF", "images", "semantic relationships", "visual maps", "mixed code and documentation"],
    "do_not_use_for": ["fast code symbol lookup", "call graph after every small edit", "secret files"]
  },
  "security": {"hooks_enabled_by_default": false, "watcher_enabled_by_default": false, "upstream_installer_allowed": false}
}
